---
title: "Contact — Slade Networks"
description: "Book a free on-site consultation or send a question. Slade Networks serves homes and small businesses in the Finger Lakes region of upstate NY."
navActive: contact
---
{% extends "base.njk" %}

{% block pageStyles %}
  <style>
    /* =========================================================
       CONTACT PAGE ONLY
    ========================================================= */

    .hero { padding: 70px 0 22px }

    h1 {
      font-size: 42px;
      line-height: 1.1;
      margin: 0 0 12px;
      letter-spacing: -0.04em;
    }

    .sub {
      font-size: 16.5px;
      color: var(--muted);
      line-height: 1.6;
      max-width: 80ch;
      margin: 0;
    }

    /* Two-column layout */
    .grid {
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 18px;
      margin-top: 22px;
      align-items: start;
    }

    .card {
      background: var(--glass);
      border: 1px solid var(--stroke);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 20px;
    }

    .card h2 {
      margin: 0 0 14px;
      font-size: 18px;
      letter-spacing: -0.02em;
    }

    /* Form */
    .fields { display: grid; gap: 10px }

    label {
      display: block;
      font-size: 12px;
      color: var(--muted2);
      margin: 0 0 6px;
    }

    input, textarea, select {
      width: 100%;
      border-radius: 14px;
      border: 1px solid var(--stroke);
      background: rgba(255,255,255,.92);
      color: var(--ink);
      padding: 12px;
      font-size: 14px;
      outline: none;
      font-family: inherit;
    }

    textarea { min-height: 130px; resize: vertical }

    input:focus, textarea:focus, select:focus {
      border-color: rgba(37,99,235,.35);
      box-shadow: 0 0 0 4px rgba(37,99,235,.16);
    }

    .row2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    /* Success notice */
    .notice {
      margin-top: 10px;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid rgba(34,197,94,.25);
      background: rgba(34,197,94,.08);
      color: rgba(15,18,26,.82);
      display: none;
      font-size: 13.5px;
      line-height: 1.5;
    }
    .notice.show { display: block }

    /* Quick info card */
    .contactBlock {
      padding: 14px 0;
      border-bottom: 1px solid var(--stroke);
    }
    .contactBlock:first-child { padding-top: 0 }
    .contactBlock:last-child { border-bottom: none; padding-bottom: 0 }

    .contactTag {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 0 5px;
    }

    .contactEmail {
      font-size: 15px;
      font-weight: 600;
      color: var(--accent);
      display: block;
      margin-bottom: 3px;
    }

    .contactCaption {
      font-size: 13px;
      color: var(--muted);
      margin: 0;
    }

    .infoRule {
      border: none;
      border-top: 1px solid var(--stroke);
      margin: 16px 0;
    }

    .subhead {
      font-size: 13px;
      font-weight: 700;
      margin: 0 0 10px;
      letter-spacing: -0.01em;
    }

    .expectList {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .expectList li {
      font-size: 13.5px;
      color: var(--muted);
      display: flex;
      align-items: flex-start;
      gap: 7px;
      line-height: 1.5;
    }

    .expectList li + li { margin-top: 6px }

    .expectList li::before {
      content: "✓";
      color: #2563EB;
      font-weight: 700;
      font-size: 12px;
      flex: 0 0 auto;
      margin-top: 1px;
    }

    .areaNote {
      margin-top: 14px;
      font-size: 13px;
      color: var(--muted2);
      line-height: 1.5;
    }

    /* Responsive */
    @media(max-width:980px) {
      .grid { grid-template-columns: 1fr }
    }

    @media(max-width:700px) {
      h1 { font-size: 34px }
      .row2 { grid-template-columns: 1fr }
    }
  </style>
{% endblock %}

{% block content %}
  <main>
    <section class="hero">
      <div class="wrap">
        <h1>Contact</h1>
        <p class="sub">Book a free on-site consultation or send a question — we'll get back to you within one business day.</p>

        <div class="grid">

          <!-- Form -->
          <div class="card">
            <h2>Request a free consultation</h2>

            <form id="contactForm" action="https://formspree.io/f/maqdblqe" method="POST">
              <input type="hidden" name="_subject" value="New Consultation Request — Slade Networks" />
              <input type="hidden" name="_next" value="./?sent=1" />

              <!-- Honeypot (spam trap) -->
              <div style="position:absolute; left:-9999px; width:1px; height:1px; overflow:hidden;" aria-hidden="true">
                <label for="website">Website</label>
                <input id="website" name="website" tabindex="-1" autocomplete="off" />
              </div>

              <div class="fields">
                <div class="row2">
                  <div>
                    <label for="name">Name</label>
                    <input id="name" name="name" autocomplete="name" placeholder="Your name" required />
                  </div>
                  <div>
                    <label for="email">Email</label>
                    <input id="email" name="email" type="email" autocomplete="email" placeholder="you@email.com" required />
                  </div>
                </div>

                <div class="row2">
                  <div>
                    <label for="who">Home or business</label>
                    <select id="who" name="home_or_business">
                      <option value="Home">Home</option>
                      <option value="Business">Business</option>
                    </select>
                  </div>
                  <div>
                    <label for="location">Town / area</label>
                    <input id="location" name="town_area" autocomplete="address-level2" placeholder="e.g. Penn Yan" />
                  </div>
                </div>

                <div>
                  <label for="service">What help is needed?</label>
                  <select id="service" name="service_needed">
                    <option value="Wi-Fi">Wi-Fi (coverage / redesign / new install)</option>
                    <option value="Cameras">Cameras + NVR</option>
                    <option value="VoIP">VoIP (UniFi Talk)</option>
                    <option value="Cabling">Structured cabling</option>
                    <option value="Gateway/Switching">Gateway / switching</option>
                    <option value="Rack">Rack build / cleanup</option>
                    <option value="LTE/5G">LTE/5G backup internet</option>
                    <option value="Support Plan">Ongoing Support Plan</option>
                    <option value="Other">Other</option>
                  </select>
                </div>

                <div>
                  <label for="timeline">Timeline</label>
                  <input id="timeline" name="timeline" placeholder="e.g. this month / next month / flexible" />
                </div>

                <div>
                  <label for="message">Project details</label>
                  <textarea id="message" name="project_details" placeholder="Briefly describe what's going on and what the goal is."></textarea>
                </div>

                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                  <button class="btn primary" type="submit">Send request</button>
                  <a class="btn" href="mailto:info@sladenetworks.com?subject=Slade%20Networks%20Consultation">Email instead</a>
                </div>

                <div id="sentNotice" class="notice" role="status" aria-live="polite">
                  Sent — we'll be in touch within one business day. If you don't hear back, email <a href="mailto:info@sladenetworks.com" style="text-decoration:underline">info@sladenetworks.com</a> directly.
                </div>
              </div>
            </form>
          </div>

          <!-- Quick info -->
          <div class="card">
            <h2>Get in touch</h2>

            <div class="contactBlock">
              <p class="contactTag">New inquiry</p>
              <a class="contactEmail" href="mailto:info@sladenetworks.com">info@sladenetworks.com</a>
              <p class="contactCaption">Consultations, questions, and quotes</p>
            </div>

            <div class="contactBlock">
              <p class="contactTag">Existing client</p>
              <a class="contactEmail" href="mailto:support@sladenetworks.com">support@sladenetworks.com</a>
              <p class="contactCaption">Troubleshooting and support plan questions</p>
            </div>

            <hr class="infoRule">

            <p class="subhead">What to expect</p>
            <ul class="expectList">
              <li>Response within one business day</li>
              <li>Free on-site visit — we come to you</li>
              <li>Written quote before any work begins</li>
            </ul>

            <p class="areaNote">Serving the Finger Lakes and surrounding areas in upstate NY — homes and small businesses.</p>
          </div>

        </div>
      </div>
    </section>
  </main>
{% endblock %}

{% block pageScript %}
  <script>
    (function () {
      // Show a success notice after redirect (?sent=1)
      const params = new URLSearchParams(window.location.search);
      if (params.get("sent") === "1") {
        const notice = document.getElementById("sentNotice");
        if (notice) notice.classList.add("show");
      }

      // Extra spam trap: if honeypot is filled, block submit.
      const form = document.getElementById("contactForm");
      if (form) {
        form.addEventListener("submit", (e) => {
          const hp = (document.getElementById("website")?.value || "").trim();
          if (hp) e.preventDefault();
        });
      }
    })();
  </script>
{% endblock %}
